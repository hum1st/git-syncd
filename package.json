{
  "name": "git-syncd",
  "version": "1.3.0",
  "description": "A library to keep git repositories in sync via git clone/pull",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "init": "npm i",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.esm.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "npm run build && jest --coverage",
    "test:coverage": "npm run build && jest --coverage",
    "lint": "eslint src tests scripts",
    "lint:fix": "eslint src tests scripts --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.esm.json --noEmit",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:setup": "node scripts/setup-repos.mjs",
    "dev:sync": "node scripts/sync-repos.mjs"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageReporters": [
      "text"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 95,
        "statements": 95
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hum1st/git-syncd"
  },
  "keywords": [
    "git",
    "sync",
    "pull"
  ],
  "author": "hum1st",
  "license": "MIT",
  "homepage": "https://github.com/hum1st/git-syncd#readme",
  "bugs": {
    "url": "https://github.com/hum1st/git-syncd/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.0.0",
    "jest": "^30.4.2",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.64.0"
  },
  "lint-staged": {
    "*.{ts,mjs}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
